{
  "name": "iahumanizada",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @iah/api db:migrate",
    "db:studio": "pnpm --filter @iah/api db:studio",
    "db:seed": "pnpm --filter @iah/api db:seed"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
