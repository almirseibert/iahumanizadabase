{
  "name": "@iah/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "simulate:webhook": "tsx scripts/simulate-webhook.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@bull-board/api": "^6.7.0",
    "@bull-board/fastify": "^6.7.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/redis-emitter": "^5.1.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@google/genai": "^1.9.0",
    "@iah/shared": "workspace:*",
    "@prisma/client": "^6.5.0",
    "argon2": "^0.41.0",
    "bullmq": "^5.34.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "googleapis": "^144.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.3.0",
    "openai": "^4.80.0",
    "pino": "^9.5.0",
    "socket.io": "^4.8.0",
    "undici": "^7.2.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@iah/tsconfig": "workspace:*",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
